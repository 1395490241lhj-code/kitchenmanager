// Copy to Local.xcconfig or run `npm run configure:ios-auth`.
// `$()` keeps `//` from being parsed as an xcconfig comment.
SUPABASE_URL = https:/$()/YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY = YOUR_PUBLISHABLE_KEY
SYNC_ENABLED = NO
SYNC_SMOKE_ENABLED = NO
// Required in addition to both flags for a one-off development smoke.
SYNC_SMOKE_ENVIRONMENT = development
// Phase 2B: independent gate for the Guest inventory merge feature.
INVENTORY_SYNC_ENABLED = NO
// Phase 2B-3: independent gate for whether the merge/sync UI is shown at all.
INVENTORY_MERGE_UI_ENABLED = NO
// Phase 2B-2: independent one-off Guest merge smoke guard, mirroring
// SYNC_SMOKE_ENABLED. Requires SYNC_SMOKE_ENVIRONMENT = development too.
GUEST_MERGE_SMOKE_ENABLED = NO
// Phase 2B-5: dogfood gates. Only ever unlock manual paths + a read-only
// diagnostics screen, never automatic sync.
INVENTORY_SYNC_DOGFOOD_ENABLED = NO
INVENTORY_SYNC_DIAGNOSTICS_ENABLED = NO
// Phase 2C-2: crash reporting abstraction only — see docs/CRASH_REPORTING.md.
// Leave disabled/empty unless you have your own internal-only DSN.
CRASH_REPORTING_ENABLED = NO
CRASH_REPORTING_DSN =
CRASH_REPORTING_ENVIRONMENT =
CRASH_REPORTING_SAMPLE_RATE = 0
