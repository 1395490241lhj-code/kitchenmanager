// Committed defaults. Local.xcconfig is optional, ignored by Git, and generated
// from the developer's environment by `npm run configure:ios-auth`.
SUPABASE_URL =
SUPABASE_PUBLISHABLE_KEY =
SYNC_ENABLED = NO
SYNC_SMOKE_ENABLED = NO
SYNC_SMOKE_ENVIRONMENT =
// Phase 2B: independent gate for the Guest inventory merge feature. Does not
// enable or depend on SYNC_ENABLED; both default NO in every configuration.
INVENTORY_SYNC_ENABLED = NO
// Phase 2B-3: independent gate for whether the merge/sync UI is even shown.
// Separate from INVENTORY_SYNC_ENABLED (the network capability) so each can
// be controlled independently; both default NO everywhere.
INVENTORY_MERGE_UI_ENABLED = NO
// Phase 2B-2: a second, independent one-off smoke guard, mirroring
// SYNC_SMOKE_ENABLED — never a product feature flag, always NO in every
// committed configuration and every Release build.
GUEST_MERGE_SMOKE_ENABLED = NO
// Phase 2B-5: dogfood gates. Independent of every flag above — dogfood only
// ever unlocks *manual* paths and a read-only diagnostics screen, never
// automatic sync. Both NO in every committed configuration and every
// Release build; never settable from a remote response.
INVENTORY_SYNC_DOGFOOD_ENABLED = NO
INVENTORY_SYNC_DIAGNOSTICS_ENABLED = NO
// Phase 2C-2: crash reporting is an abstraction only this phase — no
// third-party SDK has been added to the project (see docs/CRASH_REPORTING.md).
// Enabling this without a real provider wired in still safely no-ops
// (CrashReportingFactory falls back to NoOpCrashReporter). NO in every
// committed configuration and every Release build; DSN is always empty here.
CRASH_REPORTING_ENABLED = NO
CRASH_REPORTING_DSN =
CRASH_REPORTING_ENVIRONMENT =
CRASH_REPORTING_SAMPLE_RATE = 0

#include? "Local.xcconfig"
