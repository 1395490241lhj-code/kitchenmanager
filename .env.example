# Existing Express / AI configuration
PORT=3000
TRUST_PROXY_HOPS=0
CORS_EXTRA_ORIGIN=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=openai/gpt-oss-120b
OPENAI_IMPORT_MODEL=
OPENAI_VISION_MODEL=
OPENAI_TRANSCRIBE_MODEL=

# Supabase public project configuration. The URL and anon/publishable key may
# eventually be used by PWA/iOS clients, but Phase 0 uses them only on Express.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_OR_PUBLISHABLE_KEY
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# OPTIONAL, last-resort fallback only. Populate this if the deployment box
# cannot resolve the Supabase JWKS hostname over DNS (Render has hit this).
# This is a JWKS document — a set of PUBLIC verification keys, not a secret —
# but it must never contain private-key fields (d/p/q/dp/dq/qi) and must
# never be committed to this repo with real values. Generate it with:
#   node scripts/fetch-supabase-jwks.mjs
# and paste the single-line JSON it prints directly into the Render
# dashboard's environment variable editor. Re-fetch and re-paste whenever
# Supabase rotates its signing keys, since this snapshot goes stale.
SUPABASE_JWKS_JSON={"keys":[{"kty":"EC","alg":"ES256","use":"sig","kid":"YOUR_KEY_ID","crv":"P-256","x":"YOUR_PUBLIC_X_COORDINATE","y":"YOUR_PUBLIC_Y_COORDINATE"}]}

# Phase 0.5 integration validation only. Remote verification refuses to run
# unless the environment is explicitly marked non-production.
SUPABASE_ENVIRONMENT=development
EXPRESS_API_BASE=http://127.0.0.1:3000
TEST_USER_A_EMAIL=
TEST_USER_A_PASSWORD=
TEST_USER_B_EMAIL=
TEST_USER_B_PASSWORD=

# Opt in only against an isolated development server. This consumes the
# current /api/me rate-limit bucket until its window expires.
AUTH_SMOKE_TEST_RATE_LIMIT=false
AUTH_SMOKE_RATE_LIMIT_REQUEST_CAP=70

# SERVER ONLY. Never expose this value to browser code, iOS configuration,
# logs, backups, or client-visible deployment variables.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SERVICE_ROLE_KEY
