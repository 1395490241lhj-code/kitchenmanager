{
  "name": "kitchenmanager",
  "version": "1.0.0",
  "private": true,
  "description": "Kitchen Manager / 厨房管理 —— 本地优先的家庭厨房库存、菜谱与购物清单工具（全栈一体化：Express 静态托管 + 小红书抓取代理）。",
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "verify:auth-phase0": "node scripts/verify-supabase-phase0.mjs",
    "verify:auth-db": "npx supabase db query --linked --file supabase/tests/auth_household_remote_verify.sql",
    "smoke:auth": "node scripts/auth-smoke.mjs",
    "validate:recipe-packs": "node scripts/validate-recipe-pack-samples.js",
    "validate:recipe-pack-data": "node scripts/validate-recipe-packs.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.2.0",
    "jose": "^5.10.0"
  },
  "devDependencies": {
    "supabase": "^2.109.1"
  }
}
