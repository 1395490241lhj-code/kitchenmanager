{
  "name": "kitchenmanager",
  "version": "1.0.0",
  "private": true,
  "description": "Kitchen Manager / 厨房管理 —— Guest-first、Local-first 的双客户端家庭厨房管理产品：原生 JavaScript PWA、SwiftUI/SwiftData iOS、Express 服务端与 Supabase 账号/库存同步基础。",
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "configure:ios-auth": "node scripts/configure-ios-auth.mjs",
    "verify:auth-phase0": "node scripts/verify-supabase-phase0.mjs",
    "verify:auth-db": "npx supabase db query --linked --file supabase/remote-verify/auth_household_remote_verify.sql",
    "smoke:auth": "node scripts/auth-smoke.mjs",
    "verify:sync-db": "npx supabase db query --linked --file supabase/remote-verify/sync_business_remote_verify.sql",
    "smoke:sync": "node scripts/sync-smoke.mjs",
    "validate:recipe-packs": "node scripts/validate-recipe-pack-samples.js",
    "validate:recipe-pack-data": "node scripts/validate-recipe-packs.js",
    "ios:release:check": "node scripts/validate-ios-release.mjs",
    "ios:release:bump-build": "node scripts/bump-ios-build.mjs",
    "ios:archive:guard": "node scripts/ios-archive-guard.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.2.0",
    "jose": "^5.10.0"
  },
  "devDependencies": {
    "supabase": "^2.109.1"
  }
}
